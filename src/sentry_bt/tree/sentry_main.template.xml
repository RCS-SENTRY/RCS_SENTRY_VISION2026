<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <ReactiveSequence name="main_loop">
      <UpdateBlackboard/>
      <SubTree ID="HardConstraintGuard"/>
      <EvaluateTacticalState tactical_state="{tactical_state}"/>
      <ForceSuccess>
        <SubTree ID="RuleActionSubtree"/>
      </ForceSuccess>

      <ReactiveFallback name="main_dispatch">
        <Sequence name="emergency_branch">
          <NeedEmergencySafety/>
          <SetSafePolicies/>
        </Sequence>

        <Sequence name="revive_branch">
          <IsDead/>
          <Fallback name="revive_fallback">
            <Sequence name="confirm_revive">
              <CanConfirmRevive/>
              <ConfirmRevive/>
            </Sequence>
            <Sequence name="buy_revive">
              <ShouldBuyImmediateRevive/>
              <ConfirmImmediateRevive/>
            </Sequence>
            <WaitRevive/>
          </Fallback>
        </Sequence>

        <Switch6 variable="{tactical_state}"
                 case_1="RETREAT"
                 case_2="RESUPPLY"
                 case_3="HOLD"
                 case_4="ENGAGE"
                 case_5="SEARCH"
                 case_6="REPOSITION">
          <SubTree ID="RetreatSubtree"/>
          <SubTree ID="ResupplySubtree"/>
          <SubTree ID="HoldSubtree"/>
          <SubTree ID="EngageSubtree"/>
          <SubTree ID="SearchSubtree"/>
          <SubTree ID="RepositionSubtree"/>
          <SubTree ID="SearchSubtree"/>
        </Switch6>
      </ReactiveFallback>

      <Sequence name="executor_layer">
        <ApplyPostureDecision/>
        <ApplyFireDecision/>
        <ApplySpinDecision/>
        <ApplySupercapDecision/>
        <PublishGoalToNavigator/>
      </Sequence>
    </ReactiveSequence>
  </BehaviorTree>

  <BehaviorTree ID="HardConstraintGuard">
    <Sequence name="HardConstraintGuard">
      <ForceSuccess>
        <HeatGuard/>
      </ForceSuccess>
      <ForceSuccess>
        <PowerGuard/>
      </ForceSuccess>
      <ForceSuccess>
        <AmmoGuard/>
      </ForceSuccess>
      <ForceSuccess>
        <SupercapGuard/>
      </ForceSuccess>
      <ForceSuccess>
        <PostureCooldownGuard/>
      </ForceSuccess>
      <ForceSuccess>
        <RuleCmdGuard/>
      </ForceSuccess>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="RuleActionSubtree">
    <Sequence name="RuleActionSubtree">
      <EvaluateRuleAction rule_action_type="{rule_action_type}"/>
      <Switch6 variable="{rule_action_type}"
               case_1="EXCHANGE_AMMO_AT_POINT"
               case_2="REMOTE_AMMO"
               case_3="REMOTE_HP"
               case_4="ACTIVATE_ENERGY"
               case_5="UNUSED"
               case_6="SWITCH_POSTURE">
        <ExchangeAmmoAtPoint/>
        <RemoteExchangeAmmo/>
        <RemoteExchangeHP/>
        <ActivateEnergyMechanism/>
        <NoRuleAction/>
        <HandlePostureSwitchRequest/>
        <NoRuleAction/>
      </Switch6>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="RetreatSubtree">
    <Sequence name="RetreatSubtree">
      <ResetGoalCandidates/>
      <EvaluateRetreatGoals/>
      <ChooseBestGoal/>
      <SetPreferredPosture posture="MOVE"/>
      <SetPreferredFirePolicy fire_policy="NORMAL"/>
      <SetSituationalSpinPreference/>
      <SetPreferredSupercapMode supercap_mode="BURST"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="ResupplySubtree">
    <Sequence name="ResupplySubtree">
      <ResetGoalCandidates/>
      <EvaluateResupplyGoals/>
      <ChooseBestGoal/>
      <SetPreferredPosture posture="MOVE"/>
      <SetPreferredFirePolicy fire_policy="HOLD_FIRE"/>
      <SetSituationalSpinPreference/>
      <SetPreferredSupercapMode supercap_mode="KEEP"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="HoldSubtree">
    <Sequence name="HoldSubtree">
      <ResetGoalCandidates/>
      <EvaluateHoldGoals/>
      <ChooseBestGoal/>
      <SetPreferredPosture posture="DEFENSE"/>
      <SetPreferredFirePolicy fire_policy="NORMAL"/>
      <SetSituationalSpinPreference/>
      <SetPreferredSupercapMode supercap_mode="OFF"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="EngageSubtree">
    <Sequence name="EngageSubtree">
      <ResetGoalCandidates/>
      <SetCombatPosturePreference/>
      <UpdateCombatFirePolicy/>
      <SetSituationalSpinPreference/>
      <SetCombatSupercapPreference/>
      <EvaluateEngageGoals/>
      <ChooseBestGoal/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="SearchSubtree">
    <Sequence name="SearchSubtree">
      <ResetGoalCandidates/>
      <EvaluateSearchGoals/>
      <ChooseBestGoal/>
      <SetPreferredPosture posture="MOVE"/>
      <SetPreferredFirePolicy fire_policy="NORMAL"/>
      <SetSituationalSpinPreference/>
      <SetPreferredSupercapMode supercap_mode="OFF"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="RepositionSubtree">
    <Sequence name="RepositionSubtree">
      <ResetGoalCandidates/>
      <EvaluateRepositionGoals/>
      <ChooseBestGoal/>
      <SetPreferredPosture posture="MOVE"/>
      <SetPreferredFirePolicy fire_policy="NORMAL"/>
      <SetSituationalSpinPreference/>
      <SetPreferredSupercapMode supercap_mode="BURST"/>
    </Sequence>
  </BehaviorTree>
</root>
